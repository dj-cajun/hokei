DATABASE_URL="file:./dev.db"
AUTH_SECRET="your-secret-key-change-in-production"

# 소셜 로그인 (프론트 SDK)
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
NEXT_PUBLIC_KAKAO_JS_KEY=""
# 카카오 로그인 버튼 활성화 (기본 off — 준비되면 true 후 Redeploy)
# NEXT_PUBLIC_KAKAO_LOGIN_ENABLED="true"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# 원탭 비활성(redirect 버튼만). localhost FedCM 콘솔 오류 방지는 HTTP에서 원탭 자동 off
# NEXT_PUBLIC_GOOGLE_DISABLE_ONE_TAP="true"

# 카카오 REST (콜백 서버 — /api/auth/kakao/callback)
KAKAO_REST_API_KEY=""

# Z.AI — 비한국어 기사 번역용 (선택, .env에 키 있으면 사용)
ZAI_API_KEY="your-z-ai-api-key"
ZAI_MODEL="glm-4-flash"

# 네이버 검색 API (뉴스 수집) — https://developers.naver.com/apps
# Secret은 보통 20자 이상. 024 오류 시 검색 API 활성화·전체 Secret 재입력
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Vercel 등: 네이버 없이 VnExpress RSS만 수집
# INGEST_RSS_ONLY=1

# Gemini (비한국어·VnExpress RSS 번역, 선택)
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash-lite"

# Google Cloud Translation API (선택)
# GOOGLE_TRANSLATE_API_KEY=""

# Vercel Cron / 수동 수집 API 보호 (프로덕션 필수)
CRON_SECRET="your-random-cron-secret"
# 뉴스 자동 수집: 매일 07:00 ICT, 일 15건 (vercel.json cron 0 0 * * * UTC)

# 로컬 프로덕션 스모크 (next start) 시 Auth.js 호스트 신뢰
# AUTH_TRUST_HOST=true

# 검색 FTS — 최초 1회 또는 DB 이전 후: npm run search:reindex

# PostgreSQL (docker compose / Neon / Supabase)
# npm run db:postgres  →  로컬 Docker
# DATABASE_URL="postgresql://hokei:hokei_local@localhost:5432/hokei"
# schema.prisma provider 를 postgresql 로 변경 후 db push (docs/DATABASE.md)

# Sentry — https://sentry.io (org: nam-bac-technology-and-service / project: javascript-nextjs)
# Settings → Client Keys (DSN) 에서 복사 · docs/SENTRY.md
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG="nam-bac-technology-and-service"
# SENTRY_PROJECT="javascript-nextjs"

# Upstash Redis — Vercel 다중 인스턴스 Rate limit (선택, 없으면 메모리 제한)
# https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob — 프로덕션 첨부 업로드 필수 (Storage → Blob)
# BLOB_READ_WRITE_TOKEN=""

# 호치민 날씨 (OpenWeatherMap — https://openweathermap.org/api)
# OPENWEATHER_API_KEY=""

# 홈 하이라이트 YouTube 영상 ID (예: dQw4w9WgXcQ → ID만)
# NEXT_PUBLIC_YOUTUBE_HIGHLIGHT_ID=""

# 프로덕션 배포: docs/DEPLOY.md · npm run predeploy -- --production
