DATABASE_URL="file:./dev.db"
AUTH_SECRET="your-secret-key-change-in-production"

# 소셜 로그인 (프론트 SDK)
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
NEXT_PUBLIC_KAKAO_JS_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# 카카오 REST (콜백 서버 — /api/auth/kakao/callback)
KAKAO_REST_API_KEY=""

# Z.AI — 비한국어 기사 번역용 (선택, .env에 키 있으면 사용)
ZAI_API_KEY="your-z-ai-api-key"
ZAI_MODEL="glm-4-flash"

# 네이버 검색 API (뉴스 수집 필수) — https://developers.naver.com/apps
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Gemini (비한국어·VnExpress RSS 번역, 선택)
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash-lite"

# Google Cloud Translation API (선택)
# GOOGLE_TRANSLATE_API_KEY=""

# Vercel Cron / 수동 수집 API 보호 (프로덕션 필수)
CRON_SECRET="your-random-cron-secret"

# 검색 FTS — 최초 1회 또는 DB 이전 후: npm run search:reindex

# PostgreSQL (docker compose / Neon / Supabase)
# npm run db:postgres  →  로컬 Docker
# DATABASE_URL="postgresql://hokei:hokei_local@localhost:5432/hokei"
# schema.prisma provider 를 postgresql 로 변경 후 db push (docs/DATABASE.md)

# Sentry (선택) — npx @sentry/wizard@latest -i nextjs
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# Upstash Redis — Vercel 다중 인스턴스 Rate limit (선택, 없으면 메모리 제한)
# https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
