generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PostTopic {
  KOREA
  TRAVEL
  VIETNAM_POLICY
  TOURIST
}

enum PostStatus {
  PUBLISHED
  DRAFT
}

enum ModerationStatus {
  VISIBLE
  HIDDEN
  REMOVED
}

enum AttachmentKind {
  IMAGE
  FILE
}

enum ReportTargetType {
  POST
  COMMENT
}

enum ReportReason {
  SPAM
  AD
  ABUSE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  kakaoId           String?            @unique
  name              String
  avatarUrl         String?
  password          String
  role              Role               @default(USER)
  isSuspended       Boolean            @default(false)
  writeBanned       Boolean            @default(false)
  emailVerified     DateTime?
  emailVerification EmailVerification?
  posts             Post[]
  comments          Comment[]
  postLikes         PostLike[]
  commentLikes      CommentLike[]
  commentDislikes   CommentDislike[]
  bookmarks         Bookmark[]
  notifications     Notification[]
  conversationsA    Conversation[]     @relation("ConversationParticipantA")
  conversationsB    Conversation[]     @relation("ConversationParticipantB")
  sentMessages      DirectMessage[]
  lifeGuides        LifeGuide[]
  partnerStores     PartnerStore[]
  couponOrders      CouponOrder[]
  couponWalletItems CouponWalletItem[]
  couponRedemptionTokens CouponRedemptionToken[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  label       String
  description String?
  icon        String     @default("Folder")
  colorClass  String     @default("bg-secondary text-muted-foreground")
  href        String
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryTree")
  posts       Post[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@index([sortOrder])
}

model Post {
  id                  String           @id @default(cuid())
  title               String
  summary             String
  content             String?
  sourceUrl           String           @unique
  sourceName          String?
  topic               PostTopic
  region              String?
  categoryId          String
  category            Category         @relation(fields: [categoryId], references: [id])
  authorId            String?
  author              User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  guestName           String?
  guestPasswordHash   String?
  isNotice            Boolean          @default(false)
  originalTitle       String?
  thumbnail           String?
  publishedAt         DateTime
  views               Int              @default(0)
  likeCount           Int              @default(0)
  commentCount        Int              @default(0)
  status              PostStatus       @default(PUBLISHED)
  moderationStatus    ModerationStatus @default(VISIBLE)
  moderatedAt         DateTime?
  moderatedById       String?
  moderationNote      String?
  isAutomated         Boolean          @default(true)
  isOutlink           Boolean          @default(false)
  isCrawl             Boolean          @default(false)
  storeName           String?
  kakaoLink           String?
  ingestedAt          DateTime         @default(now())
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  attachments         PostAttachment[]
  comments            Comment[]
  likes               PostLike[]
  bookmarks           Bookmark[]

  @@index([categoryId])
  @@index([likeCount])
  @@index([moderationStatus])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([topic])
  @@index([region])
  @@index([ingestedAt])
  @@index([authorId])
  @@index([isAutomated])
  @@index([storeName])
  @@index([isCrawl])
}

model PostAttachment {
  id        String         @id @default(cuid())
  postId    String
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  fileName  String
  mimeType  String
  size      Int
  kind      AttachmentKind
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  @@index([postId])
}

model Comment {
  id                String    @id @default(cuid())
  postId            String
  post              Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId          String?
  parent            Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children          Comment[] @relation("CommentReplies")
  authorId          String?
  author            User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  guestName         String?
  guestPasswordHash String?
  content           String
  likeCount         Int       @default(0)
  dislikeCount      Int       @default(0)
  isHidden          Boolean   @default(false)
  hiddenAt          DateTime?
  hiddenById        String?
  createdAt         DateTime  @default(now())
  likes             CommentLike[]
  dislikes          CommentDislike[]

  @@index([postId])
  @@index([parentId])
  @@index([isHidden])
  @@index([createdAt])
  @@index([authorId])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@index([createdAt])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([createdAt])
}

model CommentDislike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  href      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([createdAt])
}

model SearchQueryStat {
  id        String   @id @default(cuid())
  query     String   @unique
  count     Int      @default(1)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([count])
}

model Conversation {
  id                   String          @id @default(cuid())
  participantAId       String
  participantBId       String
  participantA         User            @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB         User            @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  contextPostId        String?
  /// O2O 쿠폰 주문 — 최근 연동 주문 ID (같은 업소 재구매 시 갱신)
  contextCouponOrderId String?
  lastMessageAt        DateTime        @default(now())
  createdAt            DateTime        @default(now())
  messages             DirectMessage[]

  @@unique([participantAId, participantBId])
  @@index([participantAId, lastMessageAt])
  @@index([participantBId, lastMessageAt])
  @@index([contextCouponOrderId])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model ContentReport {
  id           String           @id @default(cuid())
  targetType   ReportTargetType
  targetId     String
  reporterId   String?
  guestContact String?
  reason       ReportReason
  detail       String?
  status       ReportStatus     @default(OPEN)
  assignedToId String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

model NewsSourceConfig {
  id         String    @id @default(cuid())
  topic      PostTopic
  type       String
  query      String?
  url        String?
  sourceName String
  isEnabled  Boolean   @default(true)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([topic, isEnabled])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String?
  targetId   String?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

model IpBlockEntry {
  id          String    @id @default(cuid())
  pattern     String    @unique
  reason      String
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
}

model StorageSnapshot {
  id                String   @id @default(cuid())
  takenAt           DateTime @default(now())
  attachmentBytes   Int      @default(0)
  attachmentCount   Int      @default(0)
  blobEstimateBytes Int?
}

enum LifeGuideKind {
  PHRASE
  DOC
}

enum LifeDomain {
  CLOTHES
  FOOD
  HOUSING
  ADMIN
  TRANSPORT
  EDUCATION
  STUDY
}

/// 의식주 위키 + 오피셜 자료실 + 교민 베트남어 공부 (v2.0)
model LifeGuide {
  id          String        @id @default(cuid())
  slug        String        @unique
  kind        LifeGuideKind
  domain      LifeDomain
  title       String
  vnText      String?
  body        String        @db.Text
  audioUrl    String?
  fileUrl     String?
  imageUrl    String?
  imageUrls   Json?
  sourceLabel String?
  externalUrl String?
  isCrawl     Boolean       @default(false)
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sortOrder   Int           @default(0)
  publishedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([domain, kind])
  @@index([sortOrder])
  @@index([publishedAt])
  @@index([authorId])
}

/// 사이트 전역 설정 (홈 유튜브 등)
model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

enum PartnerCategory {
  FOOD
  BEAUTY
  CLINIC
  SERVICE
  OTHER
}

enum PartnerPlan {
  BASIC
  STANDARD
  PREMIUM
}

enum PartnerStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PartnerBannerSlot {
  HOME_BOTTOM
  HOME_TOP
  NEWS_INLINE
  PROMO_TOP
}

/// 제휴 업소 — 모바일 LP `/store/{slug}`
model PartnerStore {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  tagline     String?
  /** 2~3줄 브랜드 소개 (description과 중복 방지) */
  introText   String?         @db.Text
  description String?         @db.Text
  /** 메뉴명·가격 (텍스트) */
  menuText    String?         @db.Text
  category    PartnerCategory
  phone       String?
  kakaoLink   String?
  mapsUrl     String?
  address     String?
  /** 교통·주차 안내 */
  locationTips String?        @db.Text
  hoursText   String?
  thumbnail   String?
  /** SNS 공유 OG 전용 (없으면 thumbnail fallback) */
  ogImageUrl  String?
  plan        PartnerPlan     @default(BASIC)
  status      PartnerStatus   @default(DRAFT)
  sortOrder   Int             @default(0)
  publishedAt DateTime?
  expiresAt   DateTime?
  ownerId     String?
  owner       User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  /** LP 하단 댓글 게시글 (없으면 홍보 글 첫 건) */
  commentPostId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  banners     PartnerBanner[]
  events      PartnerEvent[]

  @@index([status])
  @@index([category])
  @@index([expiresAt])
  @@index([sortOrder])
  @@index([ownerId])
}

/// 홈·게시판 제휴 배너 슬롯
model PartnerBanner {
  id        String            @id @default(cuid())
  storeId   String
  store     PartnerStore      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  slot      PartnerBannerSlot
  imageUrl  String
  /** HOME_TOP — 768px 미만 모바일 전용 (없으면 imageUrl 사용) */
  mobileImageUrl String?
  altText   String?
  linkSlug  String?
  sortOrder Int               @default(0)
  isActive  Boolean           @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([slot, isActive])
  @@index([storeId])
}

enum PartnerEventType {
  VIEW
  KAKAO_CLICK
  PHONE_CLICK
  MAPS_CLICK
  BANNER_CLICK
}

/// 제휴 업소 LP·배너 클릭 통계 (Phase 2)
model PartnerEvent {
  id            String           @id @default(cuid())
  storeId       String
  store         PartnerStore     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  eventType     PartnerEventType
  userAgentHash String?
  createdAt     DateTime         @default(now())

  @@index([storeId, eventType])
  @@index([createdAt])
}

/// 일별 자동 수집 로그 (하루 10건 제한 추적)
model NewsIngestRun {
  id           String   @id @default(cuid())
  runAt        DateTime @default(now())
  inserted     Int      @default(0)
  skipped      Int      @default(0)
  errors       String?
  errorDetails String?
  durationMs   Int?
  triggeredBy  String?
  timezone     String   @default("Asia/Ho_Chi_Minh")
}

// --- O2O Coupon (merged from coupon-pilot) ---

enum CouponPaymentMethod {
  bank_qr
  cash_at_store
}

enum CouponOrderStatus {
  pending_payment
  payment_pending_review
  paid
  cancelled
}

enum CouponWalletStatus {
  issued
  redeemed
  expired
  cancelled
}

enum CouponSettlementStatus {
  pending
  completed
  failed
}

enum CouponStaffRole {
  cashier
  scanner
  manager
}

enum CouponAuditAction {
  staff_login
  redeemed
  cash_confirmed
  close_day
}

model CouponAgency {
  id                String   @id @default(uuid())
  name              String
  loginId           String   @unique @map("login_id")
  passwordHash      String   @map("password_hash")
  balance           Decimal  @default(0) @db.Decimal(12, 2)
  commissionFixed   Decimal  @default(3000) @map("commission_fixed") @db.Decimal(12, 2)
  commissionPercent Decimal? @map("commission_percent") @db.Decimal(5, 2)
  bankName          String?  @map("bank_name")
  bankAccount       String?  @map("bank_account")
  bankHolder        String?  @map("bank_holder")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  products      CouponProduct[]
  transactions  CouponPlatformTxn[]
  settlements   CouponSettlement[]
  usedTokens    CouponRedemptionToken[] @relation("CouponRedemptionUsedBy")
  staff         CouponAgencyStaff[]
  auditLogs     CouponAuditLog[]
  posDevices    CouponPosDevice[]

  @@map("coupon_agencies")
}

model CouponPosDevice {
  id         String    @id @default(uuid())
  agencyId   String    @map("agency_id")
  name       String
  apiKeyHash String    @map("api_key_hash")
  lastUsedAt DateTime? @map("last_used_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  agency CouponAgency @relation(fields: [agencyId], references: [id])

  @@index([agencyId, isActive])
  @@map("coupon_pos_devices")
}

model CouponProduct {
  id          String   @id @default(uuid())
  agencyId    String   @map("agency_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  agency  CouponAgency       @relation(fields: [agencyId], references: [id])
  orders  CouponOrder[]
  walletItems CouponWalletItem[]

  @@index([agencyId])
  @@map("coupon_products")
}

model CouponOrder {
  id            String              @id @default(uuid())
  userId        String              @map("user_id")
  productId     String              @map("product_id")
  amount        Decimal             @db.Decimal(12, 2)
  status        CouponOrderStatus   @default(pending_payment)
  paymentMethod CouponPaymentMethod @default(bank_qr) @map("payment_method")
  paymentRef    String?             @map("payment_ref")
  paidAt        DateTime?           @map("paid_at")
  createdAt     DateTime            @default(now()) @map("created_at")

  buyer   User           @relation(fields: [userId], references: [id])
  product CouponProduct  @relation(fields: [productId], references: [id])
  walletItem CouponWalletItem?

  @@index([userId])
  @@map("coupon_orders")
}

model CouponWalletItem {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  productId  String             @map("product_id")
  orderId    String?            @unique @map("order_id")
  status     CouponWalletStatus @default(issued)
  issuedAt   DateTime           @default(now()) @map("issued_at")
  redeemedAt DateTime?          @map("redeemed_at")
  expiresAt  DateTime?          @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  buyer            User                    @relation(fields: [userId], references: [id])
  product          CouponProduct           @relation(fields: [productId], references: [id])
  order            CouponOrder?            @relation(fields: [orderId], references: [id])
  redemptionTokens CouponRedemptionToken[]
  platformTxn      CouponPlatformTxn?

  @@index([userId, status])
  @@map("coupon_wallet_items")
}

model CouponRedemptionToken {
  id             String    @id @default(uuid())
  jti            String    @unique
  walletItemId   String    @map("wallet_item_id")
  userId         String    @map("user_id")
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  usedAt         DateTime? @map("used_at")
  usedByAgencyId String?   @map("used_by_agency_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  walletItem   CouponWalletItem @relation(fields: [walletItemId], references: [id])
  buyer        User             @relation(fields: [userId], references: [id])
  usedByAgency CouponAgency?    @relation("CouponRedemptionUsedBy", fields: [usedByAgencyId], references: [id])

  @@index([walletItemId])
  @@map("coupon_redemption_tokens")
}

model CouponPlatformTxn {
  id           String    @id @default(uuid())
  agencyId     String    @map("agency_id")
  walletItemId String    @unique @map("wallet_item_id")
  amount       Decimal   @db.Decimal(12, 2)
  productPrice Decimal?  @map("product_price") @db.Decimal(12, 2)
  productName  String    @map("product_name")
  occurredAt   DateTime  @map("occurred_at")
  settlementId String?   @map("settlement_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  agency       CouponAgency      @relation(fields: [agencyId], references: [id])
  walletItem   CouponWalletItem  @relation(fields: [walletItemId], references: [id])
  settlement   CouponSettlement? @relation(fields: [settlementId], references: [id])

  @@index([agencyId, occurredAt])
  @@index([settlementId])
  @@map("coupon_platform_txns")
}

model CouponSettlement {
  id               String                 @id @default(uuid())
  agencyId         String                 @map("agency_id")
  periodStart      DateTime               @map("period_start") @db.Date
  periodEnd        DateTime               @map("period_end") @db.Date
  totalAmount      Decimal                @map("total_amount") @db.Decimal(12, 2)
  transactionCount Int                    @map("transaction_count")
  status           CouponSettlementStatus @default(pending)
  settledAt        DateTime?              @map("settled_at")
  createdAt        DateTime               @default(now()) @map("created_at")

  agency       CouponAgency        @relation(fields: [agencyId], references: [id])
  transactions CouponPlatformTxn[]

  @@index([agencyId])
  @@map("coupon_settlements")
}

model CouponAgencyStaff {
  id        String          @id @default(uuid())
  agencyId  String          @map("agency_id")
  name      String
  pinHash   String          @map("pin_hash")
  role      CouponStaffRole
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")

  agency    CouponAgency     @relation(fields: [agencyId], references: [id])
  auditLogs CouponAuditLog[]

  @@index([agencyId, isActive])
  @@map("coupon_agency_staff")
}

model CouponAuditLog {
  id         String            @id @default(uuid())
  agencyId   String            @map("agency_id")
  staffId    String?           @map("staff_id")
  action     CouponAuditAction
  metadata   Json?
  occurredAt DateTime          @default(now()) @map("occurred_at")

  agency CouponAgency       @relation(fields: [agencyId], references: [id])
  staff  CouponAgencyStaff? @relation(fields: [staffId], references: [id])

  @@index([agencyId, occurredAt])
  @@index([agencyId, action, occurredAt])
  @@map("coupon_audit_logs")
}
