generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum PostTopic {
  KOREA
  TRAVEL
  VIETNAM_POLICY
  TOURIST
}

enum PostStatus {
  PUBLISHED
  DRAFT
}

enum ModerationStatus {
  VISIBLE
  HIDDEN
  REMOVED
}

enum AttachmentKind {
  IMAGE
  FILE
}

enum ReportTargetType {
  POST
  COMMENT
}

enum ReportReason {
  SPAM
  AD
  ABUSE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  kakaoId           String?            @unique
  name              String
  password          String
  role              Role               @default(USER)
  emailVerified     DateTime?
  emailVerification EmailVerification?
  posts             Post[]
  comments          Comment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  label       String
  description String?
  icon        String     @default("Folder")
  colorClass  String     @default("bg-secondary text-muted-foreground")
  href        String
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryTree")
  posts       Post[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
  @@index([sortOrder])
}

model Post {
  id                  String           @id @default(cuid())
  title               String
  summary             String
  content             String?
  sourceUrl           String           @unique
  sourceName          String?
  topic               PostTopic
  categoryId          String
  category            Category         @relation(fields: [categoryId], references: [id])
  authorId            String?
  author              User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  guestName           String?
  guestPasswordHash   String?
  isNotice            Boolean          @default(false)
  originalTitle       String?
  thumbnail           String?
  publishedAt         DateTime
  views               Int              @default(0)
  commentCount        Int              @default(0)
  status              PostStatus       @default(PUBLISHED)
  moderationStatus    ModerationStatus @default(VISIBLE)
  moderatedAt         DateTime?
  moderatedById       String?
  moderationNote      String?
  isAutomated         Boolean          @default(true)
  ingestedAt          DateTime         @default(now())
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  attachments         PostAttachment[]
  comments            Comment[]

  @@index([categoryId])
  @@index([moderationStatus])
  @@index([publishedAt])
  @@index([status, publishedAt])
  @@index([topic])
  @@index([ingestedAt])
  @@index([authorId])
  @@index([isAutomated])
}

model PostAttachment {
  id        String         @id @default(cuid())
  postId    String
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  fileName  String
  mimeType  String
  size      Int
  kind      AttachmentKind
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())

  @@index([postId])
}

model Comment {
  id                String   @id @default(cuid())
  postId            String
  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId          String?
  author            User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  guestName         String?
  guestPasswordHash String?
  content           String
  isHidden          Boolean  @default(false)
  hiddenAt          DateTime?
  hiddenById        String?
  createdAt         DateTime @default(now())

  @@index([postId])
  @@index([isHidden])
  @@index([createdAt])
  @@index([authorId])
}

model ContentReport {
  id           String           @id @default(cuid())
  targetType   ReportTargetType
  targetId     String
  reporterId   String?
  guestContact String?
  reason       ReportReason
  detail       String?
  status       ReportStatus     @default(OPEN)
  assignedToId String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

model NewsSourceConfig {
  id         String    @id @default(cuid())
  topic      PostTopic
  type       String
  query      String?
  url        String?
  sourceName String
  isEnabled  Boolean   @default(true)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([topic, isEnabled])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String?
  targetId   String?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

model IpBlockEntry {
  id          String    @id @default(cuid())
  pattern     String    @unique
  reason      String
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
}

model StorageSnapshot {
  id                String   @id @default(cuid())
  takenAt           DateTime @default(now())
  attachmentBytes   Int      @default(0)
  attachmentCount   Int      @default(0)
  blobEstimateBytes Int?
}

/// 일별 자동 수집 로그 (하루 10건 제한 추적)
model NewsIngestRun {
  id           String   @id @default(cuid())
  runAt        DateTime @default(now())
  inserted     Int      @default(0)
  skipped      Int      @default(0)
  errors       String?
  errorDetails String?
  durationMs   Int?
  triggeredBy  String?
  timezone     String   @default("Asia/Ho_Chi_Minh")
}
