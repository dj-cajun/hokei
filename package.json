{
  "name": "hokei",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "help": "tsx scripts/print-help.ts",
    "env:auth-secret": "tsx scripts/rotate-auth-secret.ts",
    "env:cron-secret": "tsx scripts/rotate-cron-secret.ts",
    "env:check": "tsx scripts/check-env.ts",
    "setup": "tsx scripts/setup-sqlite.ts",
    "setup:pg": "tsx scripts/setup-postgres.ts",
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:seed:e2e": "tsx scripts/seed-e2e.ts",
    "verify": "tsx scripts/verify-security.ts",
    "predeploy": "tsx scripts/predeploy.ts",
    "predeploy:prod": "tsx scripts/predeploy.ts --production",
    "vercel:env": "tsx scripts/print-vercel-env.ts",
    "vercel:env:sync": "tsx scripts/sync-vercel-env.ts",
    "vercel:deploy": "vercel deploy --prod --yes",
    "db:migrate:deploy": "prisma migrate deploy",
    "check": "npm run lint && npm run test && npm run build",
    "naver:test": "tsx scripts/test-naver-api.ts",
    "search:pg:setup": "tsx scripts/setup-pg-search.ts",
    "db:migrate:sqlite-to-pg": "tsx scripts/migrate-sqlite-to-pg.ts",
