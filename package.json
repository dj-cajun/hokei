{
  "name": "hokei",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "help": "tsx scripts/print-help.ts",
    "env:auth-secret": "tsx scripts/rotate-auth-secret.ts",
    "env:cron-secret": "tsx scripts/rotate-cron-secret.ts",
    "vercel:cron-secret": "tsx scripts/sync-cron-secret-vercel.ts",
    "env:check": "tsx scripts/check-env.ts",
    "setup": "tsx scripts/setup-postgres.ts",
    "setup:pg": "tsx scripts/setup-postgres.ts",
    "dev": "tsx scripts/dev-local.ts",
    "dev:clean": "rm -rf .next && npm run dev",
    "postinstall": "tsx scripts/prisma-generate-for-deploy.ts && tsx scripts/ensure-prisma-client.ts",
    "build": "tsx scripts/prisma-generate-for-deploy.ts && next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:seed:e2e": "tsx scripts/seed-e2e.ts",
    "verify": "tsx scripts/verify-security.ts",
    "predeploy": "tsx scripts/predeploy.ts",
    "predeploy:prod": "tsx scripts/predeploy.ts --production",
    "vercel:env": "tsx scripts/print-vercel-env.ts",
    "vercel:env:sync": "tsx scripts/sync-vercel-env.ts",
    "deploy": "tsx scripts/deploy-via-git.ts",
    "deploy:full": "npm run predeploy:prod && npm run deploy",
    "vercel:deploy": "tsx scripts/ensure-vercel-cli.ts && vercel deploy --prod --yes",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:prod": "tsx scripts/migrate-prod.ts",
    "check": "npm run lint && npm run test && npm run build",
    "naver:test": "tsx scripts/test-naver-api.ts",
    "auth:check": "tsx scripts/check-social-auth.ts",
    "auth:check:prod": "tsx scripts/check-social-auth.ts -- --production",
    "check:prod": "node scripts/check-prod-pages.mjs",
    "check:prod:browser": "node scripts/check-prod-browser.mjs",
    "search:pg:setup": "tsx scripts/setup-pg-search.ts",
    "db:generate": "tsx scripts/prisma-generate-for-deploy.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:categories": "tsx prisma/run-seed-categories.ts",
    "db:sync:category-descriptions": "tsx scripts/sync-category-descriptions.ts",
    "db:studio": "prisma studio",
    "db:postgres": "docker compose up -d postgres",
    "db:postgres:stop": "docker compose stop postgres",
    "db:postgres:logs": "docker compose logs -f postgres",
    "db:pg:generate": "tsx scripts/prisma-pg.ts generate",
    "db:pg:push": "tsx scripts/prisma-pg.ts db push",
    "db:pg:migrate": "tsx scripts/prisma-pg.ts migrate dev",
    "db:pg:studio": "tsx scripts/prisma-pg.ts studio",
    "db:pg:setup": "npm run setup:pg",
    "search:reindex": "tsx scripts/reindex-search-fts.ts",
    "news:ingest": "tsx scripts/prisma-generate-for-deploy.ts && tsx scripts/news-ingest.ts",
    "news:check:prod": "tsx scripts/check-ingest-ready.ts --neon",
    "news:reset": "tsx scripts/reset-automated-news.ts",
    "news:reset:neon": "tsx scripts/news-reset-production.ts",
    "news:scrape:setup": "pip3 install -r scripts/python/requirements.txt && python3 -m playwright install chromium",
    "news:scrape:test": "python3 scripts/python/naver_scrape.py \"호치민 한인\" 5",
    "gemini:test": "tsx scripts/test-gemini.ts",
    "gemini:retranslate": "tsx scripts/retranslate-gemini.ts",
    "debug:post": "tsx scripts/debug-post.ts",
    "debug:post:neon": "tsx scripts/debug-post.ts -- --neon",
    "debug:post:neon:prisma": "tsx scripts/debug-post.ts -- --neon-prisma",
    "health:post:prod": "node scripts/curl-health-post-prod.mjs",
    "health:post-render:prod": "HEALTH_KIND=post-render node scripts/curl-health-post-prod.mjs",
    "news:prod:sync": "tsx scripts/sync-vercel-env.ts",
    "news:prod:update": "tsx scripts/sync-vercel-env.ts && INGEST_RSS_ONLY=1 tsx scripts/news-reset-production.ts -- --full --keep-pg && tsx scripts/backfill-thumbnails.ts -- --neon --missing-only --skip-generate && npm run db:generate",
    "news:backfill-thumbnails": "tsx scripts/backfill-thumbnails.ts",
    "news:seed-fallback-thumbnails": "tsx scripts/seed-fallback-thumbnails.ts",
    "news:reclassify": "tsx scripts/reclassify-news-categories.ts",
    "admin:promote": "tsx scripts/promote-admin.ts",
    "news:pipeline": "tsx scripts/prisma-generate-for-deploy.ts && tsx scripts/run-news-pipeline.ts",
    "news:refresh-bodies": "tsx scripts/refresh-article-bodies.ts",
    "news:clean-content": "tsx scripts/clean-post-content.ts",
    "news:dedupe": "tsx scripts/dedupe-posts.ts",
    "news:prune-travel": "tsx scripts/prune-travel-non-korea.ts",
    "news:prune-off-topic": "tsx scripts/prune-off-topic-posts.ts",
    "news:prune-empty": "tsx scripts/prune-empty-content-news.ts",
    "news:prune-no-thumbnail": "tsx scripts/prune-no-thumbnail-news.ts",
    "news:queries": "tsx -e \"import { listNaverSearchQueries } from './src/lib/news/naver-search-queries.ts'; console.log(JSON.stringify(listNaverSearchQueries(), null, 2))\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "jsdom": "27.0.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.55.0",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "isomorphic-dompurify": "^3.16.0",
    "jsdom": "27.0.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.6.1",
    "vitest": "^4.1.8"
  }
}
