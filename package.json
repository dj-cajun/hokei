    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:categories": "tsx prisma/run-seed-categories.ts",
    "db:sync:category-descriptions": "tsx scripts/sync-category-descriptions.ts",
    "db:studio": "prisma studio",
    "db:postgres": "docker compose up -d postgres",
    "db:postgres:stop": "docker compose stop postgres",
    "db:postgres:logs": "docker compose logs -f postgres",
    "db:pg:generate": "tsx scripts/prisma-pg.ts generate",
    "db:pg:push": "tsx scripts/prisma-pg.ts db push",
    "db:pg:migrate": "tsx scripts/prisma-pg.ts migrate dev",
    "db:pg:studio": "tsx scripts/prisma-pg.ts studio",
    "db:pg:setup": "npm run setup:pg",
    "search:reindex": "tsx scripts/reindex-search-fts.ts",
    "news:ingest": "tsx scripts/news-ingest.ts",
    "news:reset": "tsx scripts/reset-automated-news.ts",
    "news:scrape:setup": "pip3 install -r scripts/python/requirements.txt && python3 -m playwright install chromium",
    "gemini:test": "tsx scripts/test-gemini.ts",
    "gemini:retranslate": "tsx scripts/retranslate-gemini.ts",
    "news:backfill-thumbnails": "tsx scripts/backfill-thumbnails.ts",
    "news:refresh-bodies": "tsx scripts/refresh-article-bodies.ts",
    "news:clean-content": "tsx scripts/clean-post-content.ts",
    "news:dedupe": "tsx scripts/dedupe-posts.ts",
    "news:prune-travel": "tsx scripts/prune-travel-non-korea.ts",
    "news:prune-off-topic": "tsx scripts/prune-off-topic-posts.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.55.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.6.1",
    "vitest": "^4.1.8"
  }
}
